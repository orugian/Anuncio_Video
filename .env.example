# ============================================
# Madara Pipeline — Environment Configuration
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit your actual .env file to the repository.

# ── Supabase (PostgreSQL + Storage) ──────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key

# ── Telegram Bot ─────────────────────────────
# Get your token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz123456789
# Your Telegram user ID (get it from @userinfobot)
AUTHORIZED_USER_ID=123456789

# ── OpenRouter (LLM Gateway) ─────────────────
# https://openrouter.ai/keys — used for semantic processing and prompt generation
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ── MuAPI (Video Generation) ─────────────────
# https://muapi.ai — API key for video generation from static images
MUAPI_KEY=your-muapi-api-key-here